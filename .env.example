# DevCrew AI Environment Configuration (Offline Local Edition)

# LLM Provider Selection: "mock" (offline rule-based simulator) or "ollama" (local Ollama instance)
LLM_PROVIDER=ollama

# Local Ollama URL (Only used if LLM_PROVIDER=ollama)
OLLAMA_API_URL=http://localhost:11434/api/generate

# Local Ollama Model Name (e.g., llama3, phi3, codellama, qwen2.5-coder)
OLLAMA_MODEL=qwen2.5-coder:3b

# FastAPI Backend Settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Directory paths
WORKSPACE_DIR=c:/Capstone project/generated_projects
DB_PATH=c:/Capstone project/devcrew_ai.db
